    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $json.transcript.toLowerCase();\n\nlet updates = {};\nlet changes = [];\n\nif (text.includes(\"8am\") && text.includes(\"6pm\")) {\n  updates.business_hours = {\n    days: \"monday-friday\",\n    start: \"8am\",\n    end: \"6pm\"\n  };\n\n  changes.push(\"Updated business hours\");\n}\n\nif (text.includes(\"gas leak\")) {\n  updates.emergency_definition = [\n    \"emergency\",\n    \"gas leak\"\n  ];\n\n  changes.push(\"Added gas leak to emergency definition\");\n}\n\nreturn {\n  json: {\n    account_id: \"demo_service_company\",\n    updates,\n    changes\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -400,
        -240
      ],
      "id": "97731e4e-ee11-489d-b9e8-3eb11b7cecab",
      "name": "Extract Onboarding Updates"
