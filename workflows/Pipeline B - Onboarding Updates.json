    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const changes = [];\n\nif ($json.updates?.business_hours) {\n  changes.push({\n    field: \"business_hours\",\n    old: $json.existing_account?.business_hours || null,\n    new: $json.updates.business_hours\n  });\n}\n\nif ($json.updates?.emergency_definition) {\n  changes.push({\n    field: \"emergency_definition\",\n    old: $json.existing_account?.emergency_definition || [],\n    new: $json.updates.emergency_definition\n  });\n}\n\nreturn {\n  json: {\n    changes\n  }\n};"
      },
