        "options": {}
      },
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        -144,
        -240
      ],
      "id": "bdb9c38b-cee9-43f8-ae1a-fd8abf2da0d6",
      "name": "Extract from File1"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const existing = $json.existing_account || {};\nconst updates = $json.updates || {};\n\nconst updatedAccount = {\n  ...existing,\n  ...updates,\n  version: \"v2\"\n};\n\nreturn {\n  json: {\n    account_memo: updatedAccount,\n\n    agent_spec: {\n      agent_name: updatedAccount.company_name + \" Assistant\",\n      voice: \"friendly_professional\",\n\n      conversation_flow: {\n        greeting: \"Thank you for calling \" + updatedAccount.company_name,\n\n        business_hours_flow: [\n          \"Collect caller name\",\n          \"Collect phone number\",\n          \"Schedule appointment\"\n        ]\n      }\n    },\n\n    changes: $json.changes || []\n  }\n};"
      },
